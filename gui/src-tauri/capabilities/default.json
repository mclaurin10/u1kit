{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "u1kit",
          "cmd": "u1kit",
          "args": true,
          "sidecar": false
        },
        {
          "name": "u1kit-sidecar",
          "cmd": "resources/sidecar/u1kit",
          "args": true,
          "sidecar": true
        }
      ]
    }
  ]
}
